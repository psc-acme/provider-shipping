{
    "name": "psc-acme/provider-shipping",
    "description": "Package provider-shipping for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProviderShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "psr/log": "^3.0",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}